{
  "manifest_version": 3,
  "name": "VeriFact — verify before you trust",
  "version": "0.1.0",
  "description": "One-click credibility check of the page you're reading, powered by your local VeriFact engine.",
  "permissions": ["activeTab", "storage"],
  "host_permissions": ["http://127.0.0.1/*", "http://localhost/*"],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "options_page": "options.html",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
