# VeriFact configuration — copy to .env and fill in what you have.
# EVERYTHING here is optional. VeriFact runs with zero keys.

# --- LLM claim analysis (pick one; unlocks deep claim extraction) ---
# VERIFACT_ANTHROPIC_API_KEY=sk-ant-...
# VERIFACT_ANTHROPIC_MODEL=claude-sonnet-4-5
# VERIFACT_OPENAI_API_KEY=sk-...
# VERIFACT_OPENAI_MODEL=gpt-4o-mini

# --- Fact-check database lookup (free key: console.cloud.google.com,
#     enable "Fact Check Tools API") ---
# VERIFACT_GOOGLE_FACTCHECK_API_KEY=AIza...

# --- Live corroboration search (pick one; free tiers available) ---
# VERIFACT_BRAVE_API_KEY=BSA...
# VERIFACT_TAVILY_API_KEY=tvly-...

# --- Server ---
# VERIFACT_HOST=127.0.0.1
# VERIFACT_PORT=8000
# VERIFACT_CORS_ORIGINS=*
